<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration | ATLAS</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&display=swap');
        body { font-family: 'Hind Siliguri', sans-serif; background-color: #f8fafc; }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4">

    <div class="bg-white p-8 rounded-[2.5rem] shadow-2xl w-full max-w-md border border-gray-100">
        <div class="text-center mb-8">
            <div class="inline-block p-4 bg-blue-50 rounded-3xl mb-4">
                <img src="https://i.ibb.co/Vv99z9W/atlas-logo.png" alt="ATLAS" class="w-12 h-12">
            </div>
            <h1 class="text-3xl font-black text-blue-800 tracking-tight">ATLAS</h1>
            <p class="text-gray-500 mt-2 font-medium">একাউন্টটি সেটআপ করে নাও</p>
        </div>

        <form id="regForm" class="space-y-5">
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2 ml-1">তোমার নাম</label>
                <input type="text" id="name" required class="w-full px-5 py-4 border-none bg-gray-100 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="উদা: আমির হামজা">
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2 ml-1">HSC ব্যাচ</label>
                <input type="text" id="hsc_batch" required class="w-full px-5 py-4 border-none bg-gray-100 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="উদা: 2026">
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2 ml-1">কলেজের নাম</label>
                <input type="text" id="college" required class="w-full px-5 py-4 border-none bg-gray-100 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="উদা: ঢাকা কলেজ">
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2 ml-1">WhatsApp নম্বর</label>
                <input type="tel" id="whatsapp" required class="w-full px-5 py-4 border-none bg-gray-100 rounded-2xl focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="01XXXXXXXXX">
            </div>

            <button type="submit" id="submitBtn" class="w-full bg-blue-700 text-white py-5 rounded-[1.5rem] font-bold text-lg shadow-lg shadow-blue-200 hover:bg-blue-800 active:scale-95 transition-all">
                শুরু করো 🚀
            </button>
        </form>
    </div>

    <script>
        // Supabase Connection Settings
        const SUPABASE_URL = 'https://gdmhswxnlhvtyfxaevnt.supabase.co';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdkbWhzd3hubGh2dHlmeGFldm50Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc2MjQyMTQsImV4cCI6MjA5MzIwMDIxNH0.0vDkuK0s6dIYWsgPmvfXXPyalpHNqkm3J--kbhck2PI';
        
        const atlasClient = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        const regForm = document.getElementById('regForm');
        
        regForm.onsubmit = async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            btn.innerText = "অপেক্ষা করো...";
            btn.disabled = true;

            const studentData = {
                name: document.getElementById('name').value,
                hsc_batch: document.getElementById('hsc_batch').value,
                college: document.getElementById('college').value,
                whatsapp: document.getElementById('whatsapp').value
            };

            // ডাটাবেসে তথ্য পাঠানো
            const { data, error } = await atlasClient
                .from('students')
                .insert([studentData]);

            if (error) {
                alert("ভুল হয়েছে: " + error.message);
                btn.innerText = "আবার চেষ্টা করো";
                btn.disabled = false;
            } else {
                // স্টুডেন্টের ফোনে ডাটা সেভ করা (যাতে বারবার ফর্ম না আসে)
                localStorage.setItem('atlas_user', JSON.stringify(studentData));
                alert("রেজিস্ট্রেশন সফল হয়েছে!");
                window.location.href = 'index.html'; // হোমপেজে নিয়ে যাবে
            }
        };
    </script>
</body>
</html>